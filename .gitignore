UI/UI/dist/

# ── OS files ──
.DS_Store
Thumbs.db
~$*

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── Docker volumes ──
pgdata/
redis-data/

# ── Costco raw data ──
costco/
