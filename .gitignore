# ── Secrets & Environment ──
.env
.env.*
*.pem
*.key

# ── Python ──
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.whl
backend/analyst_backend/check.py
# ── ML outputs (regenerated by pipeline — match at any depth) ──
**/ml/output/
**/ml/models/

# ── Database dumps (too large for git) ──
*.backup
*.backup_*
*.dump
*.sql.gz
**/db/dumps/
**/db/*_dump.sql
# Master dumps named with a date (pg_dump output)
**/db/walmart_crp_master_*.sql
**/db/*_master_*.sql
# pgAdmin GUI backup dumps accidentally placed in migrations/
# (real migrations follow YYYY_MM_DD_<feature>.sql naming)
**/db/migrations/walmart_crp_*.sql

# ── Uploads (client data — never commit) ──
**/uploads/

# ── Node / Angular ──
UI/UI/node_modules/
UI/UI/.angular/
UI/UI/dist/

# ── OS files ──
.DS_Store
Thumbs.db
~$*

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── Docker volumes ──
**/pgdata/
**/redis-data/

# ── Tenant raw data (client Excel files — never commit) ──
**/costco/
**/walmart/
**/target/
# Zipped client drops (whole dataset bundles)
**/costco*.zip
**/walmart*.zip
**/target*.zip
*.zip

# ── Temporary commit-message scratchpads ──
.commit_msg_*.txt

# ── Claude Code local docs (never commit) ──
CLAUDE.md
.claude/

# CTO methodology docs — kept out of git, shared out-of-band
