# ── Secrets & Environment ──
.env
*.pem
*.key

# ── Python ──
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.whl

# ── ML outputs (regenerated by pipeline — match at any depth) ──
**/ml/output/
**/ml/models/

# ── Database dumps (too large for git) ──
*.backup
*.backup_*
*.dump
*.sql.gz
**/db/dumps/
**/db/*_dump.sql

# ── Uploads (client data — never commit) ──
**/uploads/

# ── Node / Angular ──
UI/UI/node_modules/
UI/UI/.angular/
UI/UI/dist/

# ── OS files ──
.DS_Store
Thumbs.db
~$*

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── Docker volumes ──
**/pgdata/
**/redis-data/

# ── Tenant raw data (client Excel files — never commit) ──
**/costco/
**/walmart/
**/target/
