# ── Copy this file to .env and fill in your values ────────────────────────────

# PostgreSQL
POSTGRES_DB=walmart_crp
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
DATABASE_URL=postgresql://your_username:your_password@localhost:5432/walmart_crp

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth — CHANGE THIS in production!
SECRET_KEY=super-secret-key-change-me

# App
ENVIRONMENT=development
LOG_LEVEL=info

# Groq LLM (for outreach email generation in ml/alerts.py)
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# LangFuse Cost Tracking (optional)
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=https://cloud.langfuse.com
