# ============================================================
# Analyst Agent — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# PostgreSQL connection string
DB_URL=postgresql://postgres:yourpassword@localhost:5432/walmart_crp

# OR use individual components:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=walmart_crp
DB_USER=postgres
DB_PASSWORD=yourpassword

# SQLite dev database (for local testing without PostgreSQL)
SQLITE_DB_PATH=./walmart_crp_dev.db

# Client configuration
CLIENT_ID=CLT-001
CLIENT_CODE=WMT

# Churn model settings
CHURN_WINDOW_DAYS=90          # days of inactivity = churned
HIGH_RISK_THRESHOLD=0.65      # churn_probability above this = HIGH
MEDIUM_RISK_THRESHOLD=0.35    # churn_probability above this = MEDIUM

# Discount guardrails (matches project plan)
MAX_DISCOUNT_HIGH_LTV=30      # %
MAX_DISCOUNT_MID_LTV=20       # %
MAX_DISCOUNT_LOW_LTV=10       # %
LTV_HIGH_THRESHOLD=1000       # USD
LTV_MID_THRESHOLD=200         # USD

# LangFuse (for agent cost tracking - add when ready)
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# OpenAI / Anthropic (for retention agent LLM)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
